// schema.prisma — GestorPyme MVP

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoCot {
  BORRADOR
  ENVIADA
  APROBADA
  RECHAZADA
  FACTURADA
  PAGADA
}

enum MetodoPago {
  TRANSFERENCIA
  EFECTIVO
  CHEQUE
  TARJETA_DEBITO
  TARJETA_CREDITO
  DEPOSITO
}

enum TipoProducto {
  PRODUCTO
  SERVICIO
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  AJUSTE
  DEVOLUCION
  STOCK_INICIAL
}

enum EstatusReserva {
  ACTIVA
  LIBERADA
  CONSUMIDA
}

model Producto {
  id            String                @id @default(cuid())
  sku           String                @unique
  nombre        String
  descripcion   String?
  categoria     String?
  tipo          TipoProducto          @default(PRODUCTO)
  unidad        String                @default("pza")
  precioBase    Decimal               @db.Decimal(12, 2)
  ivaPct        Decimal               @db.Decimal(5, 2) @default(16)
  stockFisico   Decimal               @db.Decimal(10, 2) @default(0)
  stockMinimo   Decimal               @db.Decimal(10, 2) @default(0)
  activo        Boolean               @default(true)
  conceptos     ConceptoCot[]
  reservas      ReservaInventario[]
  movimientos   MovimientoInventario[]
  creadoEn      DateTime              @default(now())
  actualizadoEn DateTime              @updatedAt
}

model ReservaInventario {
  id               String         @id @default(cuid())
  productoId       String
  producto         Producto       @relation(fields: [productoId], references: [id])
  cotizacionId     String
  cotizacion       Cotizacion     @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  cantidad         Decimal        @db.Decimal(10, 2)
  fechaReserva     DateTime       @default(now())
  fechaVencimiento DateTime?
  estatus          EstatusReserva @default(ACTIVA)
  creadoEn         DateTime       @default(now())
  actualizadoEn    DateTime       @updatedAt
}

model MovimientoInventario {
  id                  String         @id @default(cuid())
  productoId          String
  producto            Producto       @relation(fields: [productoId], references: [id])
  tipoMovimiento      TipoMovimiento
  cantidad            Decimal        @db.Decimal(10, 2)
  stockFisicoAnterior Decimal        @db.Decimal(10, 2)
  stockFisicoNuevo    Decimal        @db.Decimal(10, 2)
  referencia          String?
  usuarioId           String?
  usuarioNombre       String?
  observaciones       String?
  fecha               DateTime       @default(now())
  creadoEn            DateTime       @default(now())
}

model Cliente {
  id             String            @id @default(cuid())
  nombre         String
  empresa        String?
  rfc            String?           @unique
  correo         String
  telefono       String?
  direccion      String?
  notas          String?
  activo         Boolean           @default(true)
  creadoEn       DateTime          @default(now())
  actualizadoEn  DateTime          @updatedAt
  cotizaciones   Cotizacion[]
  recordatorios  LogRecordatorio[]
}

model Cotizacion {
  id              String            @id @default(cuid())
  numero          String            @unique
  clienteId       String
  cliente         Cliente           @relation(fields: [clienteId], references: [id])
  estado          EstadoCot         @default(BORRADOR)
  fecha           DateTime          @default(now())
  vencimiento     DateTime?
  subtotal        Decimal           @db.Decimal(12, 2)
  total           Decimal           @db.Decimal(12, 2)
  notas           String?
  conceptos       ConceptoCot[]
  impuestos       ImpuestoCot[]
  pagos           Pago[]
  historial       HistorialCot[]
  recordatorios   LogRecordatorio[]
  reservas        ReservaInventario[]
  creadoPorId     String?
  creadoPorEmail  String?
  creadoPorNombre String?
  creadoEn        DateTime          @default(now())
  actualizadoEn   DateTime          @updatedAt
}

model ConceptoCot {
  id             String     @id @default(cuid())
  cotizacionId   String
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  productoId     String?
  producto       Producto?  @relation(fields: [productoId], references: [id])
  descripcion    String
  unidad         String?
  cantidad       Decimal    @db.Decimal(10, 2)
  precioUnitario Decimal    @db.Decimal(12, 2)
  subtotal       Decimal    @db.Decimal(12, 2)
  orden          Int        @default(0)
}

model ImpuestoCot {
  id            String     @id @default(cuid())
  cotizacionId  String
  cotizacion    Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  nombre        String
  tasa          Decimal    @db.Decimal(5, 2)
  monto         Decimal    @db.Decimal(12, 2)
  orden         Int        @default(0)
}

model Pago {
  id              String     @id @default(cuid())
  cotizacionId    String
  cotizacion      Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  monto           Decimal    @db.Decimal(12, 2)
  fecha           DateTime   @default(now())
  metodo          MetodoPago
  referencia      String?
  creadoPorId     String?
  creadoPorEmail  String?
  creadoPorNombre String?
  creadoEn        DateTime   @default(now())
}

model HistorialCot {
  id              String     @id @default(cuid())
  cotizacionId    String
  cotizacion      Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  estadoAnterior  EstadoCot?
  estadoNuevo     EstadoCot
  nota            String?
  creadoPorId     String?
  creadoPorEmail  String?
  creadoPorNombre String?
  creadoEn        DateTime   @default(now())
}

model LogRecordatorio {
  id               String     @id @default(cuid())
  cotizacionId     String
  cotizacion       Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  clienteId        String?
  cliente          Cliente?   @relation(fields: [clienteId], references: [id])
  clienteEmail     String?
  saldoPendiente   Decimal    @db.Decimal(12, 2)
  enviadoPorId     String?
  enviadoPorEmail  String?
  enviadoPorNombre String?
  enviadoEn        DateTime   @default(now())
  exitoso          Boolean    @default(true)
  error            String?
}
